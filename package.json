{
  "name": "kfz",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@11.11.0+sha512.4463f65fd80ed80d69bc1d4bf163ee94f605c7380fc318bb5b2ebe15f8cd12d49c51a4d59e951b401e764d3b6ca751cbf51bc50ed7001a6bcb4935e684c34882",
  "description": "German license plate lookup — PWA + Watch capture",
  "scripts": {
    "refresh-kfz-data": "bash scripts/refresh-kfz-data.sh",
    "data:seed": "node scripts/seed-from-list.mjs",
    "data:seed:counts": "node scripts/seed-from-list.mjs --counts tmp/kfz_stats.json",
    "data:fix-count": "node scripts/fix-count.mjs",
    "db:init": "supabase init",
    "db:login": "supabase login",
    "db:link": "supabase link --project-ref wchzccrcqlxgsftjbpgn",
    "db:config:push": "supabase config push",
    "db:migration:new": "supabase migration new",
    "db:local:start": "supabase start",
    "db:local:stop": "supabase stop",
    "db:local:status": "supabase status",
    "db:local:push": "supabase db push --local",
    "db:local:reset": "bash scripts/db-local-reset.sh",
    "db:local:reset:empty": "bash scripts/db-local-reset.sh --empty",
    "db:local:restore:fixtures": "bash scripts/restore-local-fixtures.sh",
    "db:remote:reset": "bash scripts/refuse-remote-reset.sh",
    "db:local:dump": "supabase db dump --local -s kfz -f tmp/dump-kfz-local.sql",
    "db:local:dump:data": "supabase db dump --local --data-only --use-copy -s kfz -f tmp/dump-kfz-local-data.sql",
    "db:remote:push": "supabase db push",
    "db:remote:pull": "supabase db pull",
    "db:remote:dump": "supabase db dump -s kfz -f tmp/dump-kfz.sql",
    "db:remote:dump:data": "supabase db dump --data-only --use-copy -s kfz -f tmp/dump-kfz-data.sql",
    "secrets:push": "bash scripts/push-secrets.sh",
    "functions:deploy": "bash scripts/deploy-functions.sh",
    "functions:serve": "supabase functions serve --env-file .env.functions.local",
    "dev": "bash scripts/dev-local.sh",
    "dev:local": "bash scripts/dev-local.sh",
    "env:local": "node scripts/write-local-env.mjs",
    "web:env": "node scripts/write-web-env.mjs",
    "assets:sync": "node scripts/sync-web-assets.mjs",
    "web:dev": "node scripts/write-web-env.mjs && node scripts/sync-web-assets.mjs && pnpm --dir web dev",
    "web:build": "node scripts/write-web-env.mjs && node scripts/sync-web-assets.mjs && pnpm --dir web build",
    "web:preview": "pnpm --dir web preview",
    "test": "pnpm test:integration",
    "test:integration": "vitest run --config test/integration/vitest.config.ts"
  },
  "devDependencies": {
    "@supabase/supabase-js": "^2.49.1",
    "dotenv": "^17.3.1",
    "pg": "^8.12.0",
    "sharp": "^0.34.5",
    "supabase": "^2.107.0",
    "typescript": "^5.9.3",
    "vitest": "^3.2.4"
  }
}
