{
  "name": "kfz",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@11.13.1+sha512.b2fc7683b8a6525414e7d13e1ba28caaddde96bf66ec540bfaeb7e702b81f3e0be4d1f295edf7f9fe0396740a8dce4509c582ddf79891f4543fea32d37645f25",
  "description": "German license plate lookup — PWA + Watch capture",
  "scripts": {
    "db:login": "supabase login",
    "db:init": "supabase init",
    "db:migration:new": "supabase migration new",
    "db:prod:link": "supabase link --project-ref wchzccrcqlxgsftjbpgn",
    "db:prod:push": "bash scripts/db-prod-push.sh",
    "db:prod:pull": "bash scripts/db-prod-pull.sh",
    "db:prod:dump": "bash scripts/db-prod-dump.sh",
    "db:prod:dump:data": "bash scripts/db-prod-dump-data.sh",
    "db:prod:reset": "bash scripts/refuse-prod-reset.sh",
    "db:prod:config:push": "bash scripts/db-prod-config-push.sh",
    "db:prod:secrets:push": "bash scripts/push-secrets-prod.sh",
    "functions:local:deploy": "bash scripts/deploy-functions-local.sh",
    "functions:prod:deploy": "bash scripts/deploy-functions-prod.sh",
    "local:up": "bash scripts/local-up.sh",
    "prod:up": "bash scripts/prod-up.sh",
    "data:prod:refresh": "bash scripts/refresh-kfz-data-prod.sh",
    "data:prod:seed": "KFZ_ENV=prod node scripts/seed-from-list.mjs",
    "data:prod:seed:counts": "KFZ_ENV=prod node scripts/seed-from-list.mjs --counts tmp/kfz_stats.json",
    "data:prod:fix-count": "KFZ_ENV=prod node scripts/fix-count.mjs",
    "db:local:start": "supabase start",
    "db:local:stop": "supabase stop",
    "db:local:status": "supabase status",
    "db:local:push": "supabase db push --local",
    "db:local:reset": "bash scripts/db-local-reset.sh",
    "db:local:reset:empty": "bash scripts/db-local-reset.sh --empty",
    "db:local:restore:fixtures": "bash scripts/restore-local-fixtures.sh",
    "db:local:dump": "supabase db dump --local -s kfz -f tmp/dump-kfz-local.sql",
    "db:local:dump:data": "supabase db dump --local --data-only --use-copy -s kfz -f tmp/dump-kfz-local-data.sql",
    "env:local": "node scripts/write-local-env.mjs",
    "data:local:seed": "KFZ_ENV=local node scripts/seed-from-list.mjs",
    "data:local:seed:counts": "KFZ_ENV=local node scripts/seed-from-list.mjs --counts tmp/kfz_stats.json",
    "data:local:fix-count": "KFZ_ENV=local node scripts/fix-count.mjs",
    "dev:local": "bash scripts/dev-local.sh",
    "web:dev": "KFZ_ENV=local node scripts/write-web-env.mjs && node scripts/sync-web-assets.mjs && pnpm --dir web dev",
    "web:build": "KFZ_ENV=prod node scripts/write-web-env.mjs && node scripts/sync-web-assets.mjs && pnpm --dir web build",
    "web:preview": "pnpm --dir web preview",
    "assets:sync": "node scripts/sync-web-assets.mjs",
    "test": "pnpm test:integration",
    "test:integration": "vitest run --config test/integration/vitest.config.ts"
  },
  "devDependencies": {
    "@supabase/supabase-js": "^2.49.1",
    "dotenv": "^17.3.1",
    "pg": "^8.12.0",
    "sharp": "^0.34.5",
    "supabase": "^2.107.0",
    "typescript": "^5.9.3",
    "vitest": "^3.2.4"
  }
}
