# Copy to .env and fill in values. Never commit .env.

# Shared Supabase project (same as hgv)
SUPABASE_PROJECT_REF=wchzccrcqlxgsftjbpgn

# Direct Postgres (Mac scripts: seed, refresh, fix-count)
SUPABASE_DB_PASSWORD=
DATABASE_URL=postgresql://postgres.wchzccrcqlxgsftjbpgn:${SUPABASE_DB_PASSWORD}@aws-1-eu-west-1.pooler.supabase.com:5432/postgres

# Supabase API (edge functions, PWA build)
SUPABASE_URL=https://wchzccrcqlxgsftjbpgn.supabase.co
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_ANON_KEY=

# PWA build (Vite) — local dev only; prod builds omit the household key
VITE_FUNCTIONS_URL=https://wchzccrcqlxgsftjbpgn.supabase.co/functions/v1
VITE_KFZ_API_KEY=

# Household API key — edge functions + Watch Shortcut; enter once in the PWA (not baked into prod)
KFZ_API_KEY=

# GitHub Pages custom domain (default for pnpm pages:prod:setup)
PAGES_CNAME=kfz.schroeder.org

# Local dev only (auto-written by scripts/write-local-env.mjs / pnpm dev:local)
# SUPABASE_PROJECT_REF=local
# SUPABASE_URL=http://127.0.0.1:54331
# KFZ_API_KEY=local-dev-key
